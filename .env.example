# Supabase Configuration
# DEVELOPMENT - Use your dev Supabase project
SUPABASE_URL_DEV=https://your-dev-project.supabase.co
SUPABASE_ANON_KEY_DEV=your-dev-anon-key

# PRODUCTION - Use your production Supabase project
SUPABASE_URL_PROD=https://your-prod-project.supabase.co
SUPABASE_ANON_KEY_PROD=your-prod-anon-key

# Environment Flag
ENVIRONMENT=development

# Authentication Bypass (development only - MUST BE FALSE in production)
BYPASS_AUTH=false
